{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/session_start_summary.py",
            "command_windows": "py -3 \"%PLUGIN_ROOT%\\hooks\\session_start_summary.py\"",
            "timeout": 10,
            "statusMessage": "Loading Trace Miner session summary"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|shell_command|functions\\.shell_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/pre_tool_use_guard.py",
            "command_windows": "py -3 \"%PLUGIN_ROOT%\\hooks\\pre_tool_use_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking Trace Miner safety policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/stop_guard.py",
            "command_windows": "py -3 \"%PLUGIN_ROOT%\\hooks\\stop_guard.py\"",
            "timeout": 15,
            "statusMessage": "Running Trace Miner final guard"
          }
        ]
      }
    ]
  }
}
